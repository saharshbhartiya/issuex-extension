{
  "manifest_version": 3,
  "name": "IssueX",
  "version": "1.0",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://github.com/*",
    "https://issuex-api.onrender.com/*"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "issuex@saharshbhartiya@gmail.com",
      "strict_min_version": "109.0"
    }
  },
  "background": {
    "scripts": ["src/background.js"]
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["src/content.js"]
    }
  ]
}
